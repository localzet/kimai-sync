# Application
NODE_ENV=development
APP_PORT=3000
LOG_LEVEL=log

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=kimai_user
DB_PASSWORD=kimai_password
DB_NAME=kimai_sync
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# Kimai API Configuration
KIMAI_URL=https://kimai.example.com
KIMAI_API_KEY=your_kimai_api_key_here
KIMAI_TIMEOUT=30000

# Notion API Configuration
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here
NOTION_TIMEOUT=30000

# Sync Configuration
# Interval for scheduled sync in minutes (default: 5 minutes)
SYNC_INTERVAL=5

# Historical sync: number of years to sync back (default: 3 years)
SYNC_HISTORY_YEARS=3

# Enable/Disable specific features
ENABLE_SCHEDULED_SYNC=true
ENABLE_NOTION_SYNC=true
ENABLE_FULL_HISTORY_SYNC=true

# Job Configuration
# Number of job retries on failure
JOB_RETRY_COUNT=3

# Delay between retries in milliseconds
JOB_RETRY_DELAY=5000

# Job timeout in milliseconds
JOB_TIMEOUT=300000

# Maximum number of concurrent jobs
JOB_CONCURRENT_JOBS=3

# Remove completed jobs from queue after this time (milliseconds)
JOB_REMOVE_ON_COMPLETE_DELAY=3600000
